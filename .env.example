# ---------------------------------------------------------------------------
# Mímir environment template. Copy to `.env` (in services/ingestion/, packages/db/,
# and apps/web/) and fill in. NEVER commit real keys — the real .env files are
# gitignored; this template is the only .env* committed.
# ---------------------------------------------------------------------------

# Database (Postgres + PostGIS). Local Docker or a cloud provider (Supabase/Neon).
# For Supabase use the *Session pooler* URI (port 5432); append &gssencmode=disable
# for the Python ingestion service (libpq GSSAPI probe stalls in some networks).
DATABASE_URL="postgresql://mimir:mimir@localhost:5432/mimir?schema=public"

# ===========================================================================
# API KEYS — one per data source. See docs/DATA_SOURCES.md. Which are free:
#
#   FREE (instant signup):   FEC, Congress.gov, Census, ProPublica Congress
#   FREE (register for key): Senate LDA, Google Civic Information, OpenStates
#   FREE (no key needed):    House Clerk disclosures, MIT Election Lab,
#                            candidate campaign websites (crawled)
#   PAID / optional:         X (Twitter) API, Anthropic (issue classification),
#                            OpenSecrets
#
# The entire core platform — districts, candidates, finance, donations, bills,
# votes, demographics — runs on the FREE government APIs. Only social posts (X)
# and platform issue-classification (Anthropic) cost money, and both are optional.
# ===========================================================================

# --- Free government APIs ---------------------------------------------------
FEC_API_KEY=""              # https://api.data.gov/signup/            (or DEMO_KEY)
CONGRESS_GOV_API_KEY=""     # https://api.congress.gov/sign-up/
CENSUS_API_KEY=""           # https://api.census.gov/data/key_signup.html
SENATE_LDA_API_KEY=""       # https://lda.senate.gov/api/register/    (optional; raises limits)

# --- Civic / district lookup ------------------------------------------------
GOOGLE_CIVIC_API_KEY=""     # https://console.cloud.google.com/ → Civic Information API
                             # Free tier; used for address → district → representative lookups.

# --- Legislative data (supplemental) ----------------------------------------
PROPUBLICA_CONGRESS_API_KEY=""  # https://www.propublica.org/datastore/api/propublica-congress-api
                                 # Free; voting records, missed-vote %, party-unity scores.
OPENSTATES_API_KEY=""           # https://openstates.org/api/register/
                                 # Free; state-level bills, votes, and legislators.

# --- Campaign finance (enrichment) ------------------------------------------
OPENSECRETS_API_KEY=""      # https://www.opensecrets.org/api/admin/index.php?function=signup
                             # Paid/academic tier; industry breakdowns, lobbying, PAC profiles.

# --- Paid / optional APIs ---------------------------------------------------
X_API_BEARER_TOKEN=""       # https://developer.x.com/en/portal/products  (paid read tiers)

# Anthropic — classifies candidate platform text into neutral issue buckets only.
ANTHROPIC_API_KEY=""        # https://console.anthropic.com/settings/keys  (paid per-token)
CLASSIFIER_MODEL="claude-sonnet-5"

# --- Web app ----------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME="Mímir"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
MIMIR_DATA_SOURCE="fixtures"   # set to "prisma" to serve live data from the database

# --- Ingestion behavior -----------------------------------------------------
INGEST_USER_AGENT="MimirCivicBot/0.1 (+https://example.org/about; contact@example.org)"
INGEST_ELECTION_CYCLE="2026"
