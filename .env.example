# ---------------------------------------------------------------------------
# Mímir environment. Copy to `.env` and fill in. NEVER commit real keys.
# ---------------------------------------------------------------------------

# Database (Postgres + PostGIS). Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://mimir:mimir@localhost:5432/mimir?schema=public"

# --- Data source API keys ---------------------------------------------------
# FEC: https://api.open.fec.gov/  (free key from api.data.gov)
FEC_API_KEY=""

# Congress.gov: https://api.congress.gov/  (free key)
CONGRESS_GOV_API_KEY=""

# U.S. Census (TIGER + ACS): https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=""

# X (Twitter) API v2 — optional; social features degrade gracefully if unset.
X_API_BEARER_TOKEN=""

# --- Platform classification (LLM) ------------------------------------------
# Used only to CLASSIFY candidate platform text into neutral issue buckets.
# Never used to generate, rank, or editorialize candidate content.
ANTHROPIC_API_KEY=""
CLASSIFIER_MODEL="claude-sonnet-5"

# --- Web app ----------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME="Mímir"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Ingestion behavior -----------------------------------------------------
INGEST_USER_AGENT="MimirCivicBot/0.1 (+https://example.org/about; contact@example.org)"
INGEST_ELECTION_CYCLE="2026"
